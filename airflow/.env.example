# Airflow user ID (run `id -u` on Linux; use 501 on macOS)
AIRFLOW_UID=501

# Queensland Fuel Price Reporting Scheme API
FUEL_REPORTING_SCHEME_URL="https://fppdirectapi-prod.fuelpricesqld.com.au/Subscriber/"
FUEL_REPORTING_API_KEY="FPDAPI SubscriberToken=your-token-here"

# Airflow encryption key — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here
