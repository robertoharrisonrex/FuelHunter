# Airflow user ID (run `id -u` on Linux; use 501 on macOS)
AIRFLOW_UID=501

# Queensland Fuel Price Reporting Scheme API
FUEL_REPORTING_SCHEME_URL="https://fppdirectapi-prod.fuelpricesqld.com.au/Subscriber/"
FUEL_REPORTING_API_KEY="FPDAPI SubscriberToken=your-token-here"

# Airflow encryption key — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here

# Production only — Airflow web server secret key and internal PostgreSQL password
AIRFLOW_SECRET_KEY=
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=

# FuelHunter managed database — both ETL and Laravel use this (production only)
# Leave unset for local dev (falls back to SQLite)
FUELDB_URL=postgresql+psycopg2://USER:PASS@HOST:25060/DBNAME?sslmode=require
